# Copiez ce fichier en .env.local (jamais commité) et remplissez les valeurs.

# ---------------------------------------------------------------------------
# Authentification multi-tenant (Phase 5) — Clerk
# Créez une application sur https://dashboard.clerk.com, activez les
# Organisations, puis collez les deux clés. Sans ces clés, la plateforme
# fonctionne en « mode démo » (compte unique ci-dessous).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---------------------------------------------------------------------------
# Mode démo (repli sans Clerk) — Phase 1
# ---------------------------------------------------------------------------
# Secret de signature des sessions (générez-en un : openssl rand -hex 32)
AUTH_SECRET=remplacez-moi-par-un-secret-aleatoire
DEMO_EMAIL=analyste@demo.bank
DEMO_PASSWORD=remplacez-moi
