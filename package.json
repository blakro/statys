    "plotly.js-dist-min": "^3.7.0",
    "react": "^18",
    "react-dom": "^18",
    "react-plotly.js": "^4.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-plotly.js": "^2.6.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
